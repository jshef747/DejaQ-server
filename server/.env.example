# Copy this file to .env and fill in your values
# cp .env.example .env

# ── External LLM ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# Model to use for hard prompts (default: gemini-2.5-flash)
# DEJAQ_EXTERNAL_MODEL=gemini-2.5-flash

# ── Redis ─────────────────────────────────────────────────────────────────────
# DEJAQ_REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# DEJAQ_CHROMA_HOST=127.0.0.1
# DEJAQ_CHROMA_PORT=8001

# ── Feature Flags ─────────────────────────────────────────────────────────────
# DEJAQ_USE_CELERY=true

# ── Model Backends ────────────────────────────────────────────────────────────
# Shared Ollama host for any service role using backend=ollama
# DEJAQ_OLLAMA_URL=http://127.0.0.1:11434
# DEJAQ_OLLAMA_TIMEOUT_SECONDS=60

# Backend selection per service role: in_process | ollama
# DEJAQ_ENRICHER_BACKEND=in_process
# DEJAQ_NORMALIZER_BACKEND=in_process
# DEJAQ_LOCAL_LLM_BACKEND=in_process
# DEJAQ_GENERALIZER_BACKEND=in_process
# DEJAQ_CONTEXT_ADJUSTER_BACKEND=in_process

# Logical model names per service role
# DEJAQ_ENRICHER_MODEL_NAME=qwen_1_5b
# DEJAQ_NORMALIZER_MODEL_NAME=gemma_e2b
# DEJAQ_LOCAL_LLM_MODEL_NAME=gemma_local
# DEJAQ_GENERALIZER_MODEL_NAME=phi_generalizer
# DEJAQ_CONTEXT_ADJUSTER_MODEL_NAME=qwen_1_5b

# ── Cache Feedback Thresholds ─────────────────────────────────────────────────
# DEJAQ_TRUSTED_THRESHOLD=3
# DEJAQ_FLAG_THRESHOLD=-3
# DEJAQ_AUTO_DELETE_THRESHOLD=-5
# DEJAQ_TRUSTED_SIMILARITY=0.20
# DEJAQ_SUPPRESSION_TTL=300
