# Copy this file to .env and fill in your values
# cp .env.example .env

# ── External LLM ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# Model to use for hard prompts (default: gemini-2.5-flash)
# DEJAQ_EXTERNAL_MODEL=gemini-2.5-flash

# ── Redis ─────────────────────────────────────────────────────────────────────
# DEJAQ_REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# DEJAQ_CHROMA_HOST=127.0.0.1
# DEJAQ_CHROMA_PORT=8001

# ── Feature Flags ─────────────────────────────────────────────────────────────
# DEJAQ_USE_CELERY=true

# ── Cache Feedback Thresholds ─────────────────────────────────────────────────
# DEJAQ_TRUSTED_THRESHOLD=3
# DEJAQ_FLAG_THRESHOLD=-3
# DEJAQ_AUTO_DELETE_THRESHOLD=-5
# DEJAQ_TRUSTED_SIMILARITY=0.20
# DEJAQ_SUPPRESSION_TTL=300
